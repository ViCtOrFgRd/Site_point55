# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=point55
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=24h

# Frontend URL (usado para CORS e links em emails)
# Em desenvolvimento: http://localhost:3000
# Em produção: https://seudominio.com.br
FRONTEND_URL=http://localhost:3000

# Backend URL (usado pelo frontend para acessar a API)
# Em desenvolvimento: http://localhost:5000
# Em produção: https://api.seudominio.com.br ou https://seudominio.com.br/api
BACKEND_URL=http://localhost:5000

# Email Configuration (Gmail SMTP)
EMAIL_USER=atendimento.sacpoint@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here

# Payment Gateway (opcional - configurar depois)
# STRIPE_SECRET_KEY=your_stripe_secret_key
# MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_token

# SuperFrete (sandbox por padrao)
SUPERFRETE_BASE_URL=https://sandbox.superfrete.com/api/v0
SUPERFRETE_CALC_PATH=/calculator
SUPERFRETE_TOKEN=your_superfrete_token_here
SUPERFRETE_AUTH_HEADER=Authorization
SUPERFRETE_AUTH_PREFIX=Bearer 
SUPERFRETE_USER_AGENT=Point55/1.0 (contato@point55.com)
SUPERFRETE_SERVICES=1,2,17
SUPERFRETE_CEP_ORIGEM=04349-000
SUPERFRETE_PESO_PADRAO=0.5
SUPERFRETE_ALTURA_PADRAO=4
SUPERFRETE_LARGURA_PADRAO=12
SUPERFRETE_COMPRIMENTO_PADRAO=17
FRETE_PADRAO=15
FRETE_GRATIS_ACIMA=200
