# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=point55
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=24h

# Frontend URL (usado para CORS e links em emails)
# Em desenvolvimento: http://localhost:3000
# Em produção: https://seudominio.com.br
FRONTEND_URL=http://localhost:3000

# Backend URL (usado pelo frontend para acessar a API)
# Em desenvolvimento: http://localhost:5000
# Em produção: https://api.seudominio.com.br ou https://seudominio.com.br/api
BACKEND_URL=http://localhost:5000

# URLs auxiliares para scripts de teste
API_URL=http://localhost:5000/api
API_BASE_URL=http://localhost:5000

# Email Configuration (Gmail SMTP)
EMAIL_USER=atendimento.sacpoint@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
# Use false apenas em ambiente controlado com inspeção TLS
EMAIL_REJECT_UNAUTHORIZED=true
# Opcional: fallback para contornar erro DNS (queryA ETIMEOUT / EDNS)
# Exemplo: EMAIL_HOST_IPV4=74.125.132.108
EMAIL_HOST_IPV4=
EMAIL_CONNECTION_TIMEOUT_MS=20000
EMAIL_GREETING_TIMEOUT_MS=15000
EMAIL_SOCKET_TIMEOUT_MS=30000

# Credenciais para scripts de teste (nao usar em producao)
TEST_USER_EMAIL=victorfiigueiredo@gmail.com
TEST_USER_PASSWORD=victor123
TEST_USER_NEW_PASSWORD=victor123
TEST_ADMIN_EMAIL=victorfiigueiredo@gmail.com
TEST_ADMIN_PASSWORD=victor123
TEST_ADMIN_EMAIL_ALT=admin2@example.com
TEST_ADMIN_PASSWORD_ALT=victor123
TEST_RECIPIENT_EMAIL=victorfiigueiredo@gmail.com
TEST_RECIPIENT_NAME=victor

# Rate limiting (milissegundos e limites)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_RECOVERY_MAX=5

# Payment Gateway (opcional - configurar depois)
# STRIPE_SECRET_KEY=your_stripe_secret_key
# MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_token

# Asaas (sandbox por padrao)
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_TOKEN=your_asaas_token_here
ASAAS_AUTH_HEADER=access_token
ASAAS_AUTH_PREFIX=
ASAAS_WEBHOOK_TOKEN=your_webhook_secret_token_here
# Fallback de sync via GET quando webhook nao chega.
# true: habilita sempre | false: desabilita sempre | vazio: auto (true em development, false em production)
ASAAS_ENABLE_GET_PAYMENT_SYNC=

# SuperFrete (sandbox por padrao)
SUPERFRETE_BASE_URL=https://sandbox.superfrete.com/api/v0
# Opcional: lista separada por virgula de bases candidatas em caso de 404
SUPERFRETE_BASE_URLS=
SUPERFRETE_CALC_PATH=/calculator
# Opcional: lista separada por virgula de paths candidatos de calculo em caso de 404
SUPERFRETE_CALC_PATHS=
SUPERFRETE_PACKAGES_PATH=/packages
SUPERFRETE_TOKEN=your_superfrete_token_here
SUPERFRETE_AUTH_HEADER=Authorization
SUPERFRETE_AUTH_PREFIX=Bearer 
SUPERFRETE_USER_AGENT=Point55/1.0 (contato@point55.com)
SUPERFRETE_REJECT_UNAUTHORIZED=true
# Opcional: caminho absoluto para certificado CA (.pem/.crt) usado na validacao TLS
SUPERFRETE_CA_CERT_PATH=
SUPERFRETE_SERVICES=1,2,17
SUPERFRETE_AUTO_CREATE_LABEL_ON_PAYMENT=false
SUPERFRETE_AUTO_PAY_LABEL_ON_PAYMENT=false
SUPERFRETE_CEP_ORIGEM=04349-000
SUPERFRETE_PESO_PADRAO=0.5
SUPERFRETE_ALTURA_PADRAO=4
SUPERFRETE_LARGURA_PADRAO=12
SUPERFRETE_COMPRIMENTO_PADRAO=17
# Fallback local quando nao houver registro em config_fallback_frete
EMBALAGEM_CAPACIDADE_P=1
EMBALAGEM_CAPACIDADE_M=3
EMBALAGEM_CAPACIDADE_G=6
EMBALAGEM_PESO_CAIXA_PADRAO=0.1
FRETE_PADRAO=15
FRETE_GRATIS_ACIMA=200

# Backup do PostgreSQL
DB_BACKUP_ENABLED=false
DB_BACKUP_CRON=0 3 * * *
DB_BACKUP_RUN_ON_START=false
DB_BACKUP_DIR=./backups/postgres
DB_BACKUP_RETENTION_DAYS=14
DB_BACKUP_FORMAT=custom
DB_BACKUP_TIMEOUT_MS=120000
DB_PGDUMP_PATH=pg_dump
DB_PGRESTORE_PATH=pg_restore
DB_PSQL_PATH=psql
