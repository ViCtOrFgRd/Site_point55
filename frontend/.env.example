# Frontend Environment Variables
# Copie este arquivo para .env.local e ajuste os valores conforme necessário

# API Backend URL (deve apontar para o backend em produção)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# URL base do frontend (usado para redirecionamentos e links canônicos)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Ambiente
NODE_ENV=development

# Frete (valores de fallback e regra de frete gratis)
NEXT_PUBLIC_FRETE_PADRAO=15
NEXT_PUBLIC_FRETE_GRATIS_ACIMA=200
