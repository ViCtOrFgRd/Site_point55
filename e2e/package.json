{
  "name": "e2e-tests",
  "version": "1.0.0",
  "description": "Testes automatizados end-to-end com agentes de IA",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:chrome": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project=mobile",
    "test:smoke": "playwright test --grep @smoke",
    "test:critical": "playwright test --grep @critical",
    "test:regression": "playwright test --grep @regression",
    "test:security": "playwright test --grep @security",
    "test:ai-generate": "ts-node ai-agent/generate-tests.ts",
    "test:ai-analyze": "ts-node ai-agent/analyze-failures.ts",
    "test:ai-update": "ts-node ai-agent/update-tests.ts",
    "test:ai-coverage": "ts-node ai-agent/coverage-analyzer.ts",
    "test:ai-quality": "ts-node ai-agent/quality-validator.ts",
    "test:ai-full": "npm run test:ai-coverage && npm run test:ai-quality && npm run test:ai-generate",
    "report": "playwright show-report",
    "codegen": "playwright codegen http://localhost:3000",
    "install-browsers": "playwright install"
  },
  "keywords": [
    "e2e",
    "playwright",
    "automation",
    "ai",
    "testing"
  ],
  "author": "Victor Silva",
  "license": "ISC",
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "^1.48.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.0.0",
    "dotenv": "^16.4.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "fs-extra": "^11.2.0",
    "openai": "^4.76.0"
  }
}
