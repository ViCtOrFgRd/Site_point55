# Configurações do Banco de Dados
DATABASE_URL=postgresql://postgres:sua_senha_aqui@localhost:5432/point55
DB_HOST=localhost
DB_PORT=5432
DB_NAME=point55
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# Autenticação JWT
JWT_SECRET=sua_chave_secreta_muito_segura_aqui_123456789
JWT_REFRESH_SECRET=sua_chave_refresh_secreta_aqui_987654321
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# API Configuration
API_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Gateway de Pagamento (escolher um)
# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=seu_token_mercadopago
MERCADOPAGO_PUBLIC_KEY=sua_public_key_mercadopago

# Stripe (alternativa)
STRIPE_SECRET_KEY=seu_stripe_secret_key
STRIPE_PUBLIC_KEY=seu_stripe_public_key

# Email Configuration (para notificações)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu_email@gmail.com
EMAIL_PASSWORD=sua_senha_app_gmail

# WhatsApp Business API (opcional)
WHATSAPP_PHONE=5511993385579
WHATSAPP_API_TOKEN=seu_token_whatsapp

# Upload de Imagens (Cloudinary recomendado)
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# Ambiente
NODE_ENV=development

# Segurança
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Analytics (opcional)
NEXT_PUBLIC_GA_ID=sua_google_analytics_id

# Sentry (opcional - monitoramento de erros)
SENTRY_DSN=seu_sentry_dsn
